{
  "name": "@doclight/express",
  "version": "0.1.0",
  "description": "Doclight observability middleware for Express applications",
  "keywords": [
    "observability",
    "ai-agents",
    "express",
    "middleware",
    "typescript"
  ],
  "license": "MIT",
  "author": "Doclight <hi@doclight.app>",
  "homepage": "https://doclight.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/doclight/sdk-express"
  },
  "bugs": "https://github.com/doclight/sdk-express/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "@doclight/node": "^0.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.17.0",
    "express": "^4.21.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  }
}
